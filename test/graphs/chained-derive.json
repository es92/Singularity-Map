{
  "nodes": [
    {
      "id": "choice",
      "edges": [
        { "id": "alpha" },
        { "id": "beta" }
      ]
    },
    {
      "id": "level",
      "activateWhen": [{ "choice": ["alpha"] }],
      "deriveWhen": [
        { "match": { "choice": ["beta"] }, "value": "L1" }
      ],
      "edges": [
        { "id": "L1" },
        { "id": "L2" }
      ]
    },
    {
      "id": "intensity",
      "derived": true,
      "deriveWhen": [
        { "match": { "level": ["L2"] }, "value": "high" },
        { "match": { "level": ["L1"] }, "value": "low" }
      ],
      "edges": [
        { "id": "high" },
        { "id": "low" }
      ]
    },
    {
      "id": "finish",
      "activateWhen": [{ "intensity": ["high"] }],
      "edges": [
        { "id": "f1" },
        { "id": "f2" }
      ]
    },
    {
      "id": "alt",
      "activateWhen": [{ "choice": ["beta"] }],
      "edges": [
        { "id": "x1" },
        { "id": "x2" }
      ]
    }
  ],
  "outcomes": {
    "templates": [
      { "id": "finished", "reachable": [{ "finish": ["f1", "f2"] }] },
      { "id": "alt-done", "reachable": [{ "alt": ["x1", "x2"] }] },
      { "id": "intense", "reachable": [{ "intensity": ["high"] }] },
      { "id": "alpha-low", "reachable": [{ "choice": ["alpha"], "level": ["L1"] }] }
    ]
  }
}
