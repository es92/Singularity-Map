{
  "nodes": [
    {
      "id": "entry",
      "edges": [
        { "id": "left" },
        { "id": "right" }
      ]
    },
    {
      "id": "signal",
      "derived": true,
      "deriveWhen": [
        { "match": { "entry": ["left"] }, "value": "hot" },
        { "match": { "entry": ["right"] }, "value": "cold" }
      ],
      "edges": [
        { "id": "hot" },
        { "id": "cold" }
      ]
    },
    {
      "id": "qualifier",
      "edges": [
        { "id": "good", "disabledWhen": [{ "signal": ["cold"] }] },
        { "id": "bad" }
      ]
    },
    {
      "id": "final",
      "activateWhen": [{ "qualifier": ["good"] }],
      "edges": [
        { "id": "f1" },
        { "id": "f2" }
      ]
    }
  ],
  "outcomes": {
    "templates": [
      { "id": "hot-finish", "reachable": [{ "signal": ["hot"], "final": ["f1", "f2"] }] },
      { "id": "cold-bad", "reachable": [{ "signal": ["cold"], "qualifier": ["bad"] }] },
      { "id": "hot-bad", "reachable": [{ "signal": ["hot"], "qualifier": ["bad"] }] }
    ]
  }
}
